# === Base de datos ===
# Para desarrollo local (SQLite):
# DATABASE_URL="file:./dev.db"
# DIRECT_URL="file:./dev.db"
#
# Supabase en producción (Railway):
# - DATABASE_URL → Connection pooling, puerto 6543 (para la app en runtime)
# - DIRECT_URL   → Direct connection, puerto 5432 (obligatorio para migraciones)
#
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-1-us-west-2.pooler.supabase.com:5432/postgres"
#
# En local con Postgres directo, puedes usar el mismo valor en ambas.
DATABASE_URL=
DIRECT_URL=

# === Telegram Bot API (opcional; deshabilitado por defecto) ===
TELEGRAM_ENABLED=false
# Solo necesarios si TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Admin ===
ADMIN_TOKEN=inventa_un_string_secreto

# === Server ===
PORT=3000
APP_BASE_URL=https://tu-app.railway.app

# === Tpaga PSE ===
TPAGA_CLIENT_ID=
TPAGA_CLIENT_SECRET=
TPAGA_BASE_URL=https://staging.apiv2.tpaga.co
# Opcional: header compartido si un proxy o soporte Tpaga lo configura
# TPAGA_WEBHOOK_SECRET=

# === Email (Gmail API) ===
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
EMAIL_USER=
# Varios correos separados por coma
SELLER_EMAIL=

# === WhatsApp (Infobip) ===
INFOBIP_API_KEY=
INFOBIP_BASE_URL=
WHATSAPP_SENDER=
