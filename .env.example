# === Base de datos ===
# Para desarrollo local (SQLite):
# DATABASE_URL="file:./dev.db"
# DIRECT_URL="file:./dev.db"
#
# Supabase en Railway:
# - DATABASE_URL → Transaction pooler, puerto 6543 (+ ?pgbouncer=true)
# - DIRECT_URL   → Session pooler, MISMO host pooler, puerto 5432 (NO uses db.*.supabase.co)
#
# Ejemplo (mismo usuario y contraseña en ambas):
# DATABASE_URL="postgresql://postgres.REF:PASS@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.REF:PASS@aws-1-us-west-2.pooler.supabase.com:5432/postgres"
#
# Si migrate falla en Railway: aplica el SQL en Supabase SQL Editor y opcionalmente PRISMA_SKIP_MIGRATE=true
DATABASE_URL=
DIRECT_URL=

# === Telegram Bot API (opcional; deshabilitado por defecto) ===
TELEGRAM_ENABLED=false
# Solo necesarios si TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Admin ===
ADMIN_TOKEN=inventa_un_string_secreto

# === Server ===
PORT=3000
APP_BASE_URL=https://tu-app.railway.app

# === Tpaga PSE ===
TPAGA_CLIENT_ID=
TPAGA_CLIENT_SECRET=
TPAGA_BASE_URL=https://staging.apiv2.tpaga.co
# Opcional: header compartido si un proxy o soporte Tpaga lo configura
# TPAGA_WEBHOOK_SECRET=

# === Email (Gmail API) ===
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
EMAIL_USER=
# Varios correos separados por coma
SELLER_EMAIL=

# === WhatsApp (Infobip) ===
INFOBIP_API_KEY=
INFOBIP_BASE_URL=
WHATSAPP_SENDER=
